#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

ALL_SOURCES=(
  ce
  anthropic/frontend-design
  github/git-commit
  dimillian/swiftui-liquid-glass
  dimillian/swiftui-ui-patterns
)

source_url() {
  case "$1" in
    ce) echo "https://github.com/EveryInc/compound-engineering-plugin.git" ;;
    anthropic/frontend-design) echo "https://github.com/anthropics/skills.git" ;;
    github/git-commit) echo "https://github.com/github/awesome-copilot.git" ;;
    dimillian/swiftui-liquid-glass) echo "https://github.com/Dimillian/Skills.git" ;;
    dimillian/swiftui-ui-patterns) echo "https://github.com/Dimillian/Skills.git" ;;
    *) return 1 ;;
  esac
}

source_prefix() {
  case "$1" in
    ce) echo "plugins/compound-engineering/skills" ;;
    anthropic/frontend-design) echo "skills/frontend-design" ;;
    github/git-commit) echo "skills/git-commit" ;;
    dimillian/swiftui-liquid-glass) echo "swiftui-liquid-glass" ;;
    dimillian/swiftui-ui-patterns) echo "swiftui-ui-patterns" ;;
  esac
}

local_prefix() {
  case "$1" in
    ce) echo "ce" ;;
    anthropic/frontend-design) echo "anthropic/frontend-design" ;;
    github/git-commit) echo "github/git-commit" ;;
    dimillian/swiftui-liquid-glass) echo "dimillian/swiftui-liquid-glass" ;;
    dimillian/swiftui-ui-patterns) echo "dimillian/swiftui-ui-patterns" ;;
  esac
}

update_subtree() {
  local ID="$1"
  local REPO_URL="$2"
  local SRC="$3"
  local DST="$4"

  local TEMP_DIR BRANCH original_dir
  TEMP_DIR=$(mktemp -d)
  BRANCH="subtree-$(echo "$ID" | tr '/' '-')"

  cd "$REPO_ROOT"
  if ! git diff --quiet 2>/dev/null || \
     ! git diff --cached --quiet 2>/dev/null; then
    echo "Error: working tree has uncommitted changes. Commit or stash them first." >&2
    rm -rf "$TEMP_DIR"
    return 1
  fi

  echo "Cloning $ID..."
  if ! git clone --depth=1 "$REPO_URL" "$TEMP_DIR"; then
    echo "Error: clone failed for $ID" >&2
    rm -rf "$TEMP_DIR"
    return 1
  fi

  echo "Splitting $ID subtree..."
  original_dir="$PWD"
  cd "$TEMP_DIR"
  git subtree split --prefix="$SRC" -b "$BRANCH"

  echo "Pulling $ID into $DST..."
  cd "$original_dir"
  cd "$REPO_ROOT"
  git fetch "$TEMP_DIR" "$BRANCH"
  git subtree pull --prefix="$DST" "$TEMP_DIR" "$BRANCH" --squash

  echo "Done."
  rm -rf "$TEMP_DIR"
}

main() {
  local errors=0
  local url src dst

  for id in "${ALL_SOURCES[@]}"; do
    echo "=== $id ==="
    url=$(source_url "$id")
    src=$(source_prefix "$id")
    dst=$(local_prefix "$id")
    update_subtree "$id" "$url" "$src" "$dst" || { echo "FAILED: $id" >&2; ((errors++)); }
    echo ""
  done

  if [ "$errors" -gt 0 ]; then
    echo "$errors source(s) failed." >&2
    exit 1
  fi
  echo "All sources updated."
}

main
