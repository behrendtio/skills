#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

ALL_SOURCES=(
  ce-brainstorm
  ce-code-review
  ce-compound
  ce-dhh-rails-style
  ce-doc-review
  ce-plan
  ce-work
  codex-review
  frontend-design
  git-commit
  swiftui-liquid-glass
  swiftui-ui-patterns
)

source_url() {
  case "$1" in
    ce-brainstorm|ce-code-review|ce-compound|ce-dhh-rails-style|ce-doc-review|ce-plan|ce-work)
      echo "https://github.com/EveryInc/compound-engineering-plugin.git" ;;
    codex-review) echo "https://github.com/steipete/agent-scripts.git" ;;
    frontend-design) echo "https://github.com/anthropics/skills.git" ;;
    git-commit) echo "https://github.com/github/awesome-copilot.git" ;;
    swiftui-liquid-glass|swiftui-ui-patterns)
      echo "https://github.com/Dimillian/Skills.git" ;;
    *) return 1 ;;
  esac
}

source_prefix() {
  case "$1" in
    ce-brainstorm) echo "plugins/compound-engineering/skills/ce-brainstorm" ;;
    ce-code-review) echo "plugins/compound-engineering/skills/ce-code-review" ;;
    ce-compound) echo "plugins/compound-engineering/skills/ce-compound" ;;
    ce-dhh-rails-style) echo "plugins/compound-engineering/skills/ce-dhh-rails-style" ;;
    ce-doc-review) echo "plugins/compound-engineering/skills/ce-doc-review" ;;
    ce-plan) echo "plugins/compound-engineering/skills/ce-plan" ;;
    ce-work) echo "plugins/compound-engineering/skills/ce-work" ;;
    codex-review) echo "skills/codex-review" ;;
    frontend-design) echo "skills/frontend-design" ;;
    git-commit) echo "skills/git-commit" ;;
    swiftui-liquid-glass) echo "swiftui-liquid-glass" ;;
    swiftui-ui-patterns) echo "swiftui-ui-patterns" ;;
  esac
}

local_prefix() {
  case "$1" in
    ce-brainstorm) echo "ce-brainstorm" ;;
    ce-code-review) echo "ce-code-review" ;;
    ce-compound) echo "ce-compound" ;;
    ce-dhh-rails-style) echo "ce-dhh-rails-style" ;;
    ce-doc-review) echo "ce-doc-review" ;;
    ce-plan) echo "ce-plan" ;;
    ce-work) echo "ce-work" ;;
    codex-review) echo "codex-review" ;;
    frontend-design) echo "frontend-design" ;;
    git-commit) echo "git-commit" ;;
    swiftui-liquid-glass) echo "swiftui-liquid-glass" ;;
    swiftui-ui-patterns) echo "swiftui-ui-patterns" ;;
  esac
}

update_subtree() {
  local ID="$1"
  local REPO_URL="$2"
  local SRC="$3"
  local DST="$4"

  local TEMP_DIR BRANCH original_dir
  TEMP_DIR=$(mktemp -d)
  BRANCH="subtree-$(echo "$ID" | tr '/' '-')"

  cd "$REPO_ROOT"
  if ! git diff --quiet 2>/dev/null || \
     ! git diff --cached --quiet 2>/dev/null; then
    echo "Error: working tree has uncommitted changes. Commit or stash them first." >&2
    rm -rf "$TEMP_DIR"
    return 1
  fi

  echo "Cloning $ID..."
  if ! git clone --depth=1 "$REPO_URL" "$TEMP_DIR"; then
    echo "Error: clone failed for $ID" >&2
    rm -rf "$TEMP_DIR"
    return 1
  fi

  echo "Splitting $ID subtree..."
  original_dir="$PWD"
  cd "$TEMP_DIR"
  git subtree split --prefix="$SRC" -b "$BRANCH"

  echo "Updating $ID into $DST..."
  cd "$original_dir"
  cd "$REPO_ROOT"
  git fetch "$TEMP_DIR" "$BRANCH"
  if [ -d "$DST" ]; then
    git subtree pull --prefix="$DST" "$TEMP_DIR" "$BRANCH" --squash
  else
    git subtree add --prefix="$DST" "$TEMP_DIR" "$BRANCH" --squash
  fi

  echo "Done."
  rm -rf "$TEMP_DIR"
}

main() {
  local errors=0
  local url src dst

  for id in "${ALL_SOURCES[@]}"; do
    echo "=== $id ==="
    url=$(source_url "$id")
    src=$(source_prefix "$id")
    dst=$(local_prefix "$id")
    update_subtree "$id" "$url" "$src" "$dst" || { echo "FAILED: $id" >&2; ((errors++)); }
    echo ""
  done

  if [ "$errors" -gt 0 ]; then
    echo "$errors source(s) failed." >&2
    exit 1
  fi
  echo "All sources updated."
}

main
